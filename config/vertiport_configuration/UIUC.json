{
  "specification_metadata": {
    "version": "1.0",
    "description": "Spatio-temporal demand modeling for UAM based on Replica trip data.",
    "routing_logic": "nearest_neighbor",
    "unit_of_analysis": "census_tract_id"
  },
  "assumptions": {
    "assignment_strategy": {
      "type": "nearest",
      "definition": "Passengers are assigned to the vertiport with the minimum geographic/Euclidean distance from their origin/destination census tract, regardless of total travel time optimization."
    },
    "multimodal_segments": {
      "option1_ram": [
        {
          "segment": "first_mile",
          "mode": "taxi",
          "ovtt_min": 5,
          "node_link": "origin_to_departure_vertiport"
        },
        {
          "segment": "middle_mile",
          "mode": "uam",
          "ovtt_min": 10,
          "node_link": "departure_vertiport_to_arrival_vertiport"
        },
        {
          "segment": "last_mile",
          "mode": "taxi",
          "ovtt_min": 5,
          "node_link": "arrival_vertiport_to_destination"
        }
      ],
      "option2_car": [
        {
          "segment": "unimodal",
          "mode": "car",
          "ovtt_min": 3,
          "node_link": "origin_to_destination"
        }
      ],
      "option3_": [
        "place_holder_add_later"
      ]
    }
  },
  "vertiports": [
    {
      "vertiport_id": "UIU",
      "city": "UIUC",
      "census_tract_id": "3.01 (Champaign, IL)",
      "type": "hub",
      "fixed_driving_cost_USD": 0,
      "fato_capacity": 12,
      "coordinates": {
        "lat": 0,
        "lon": 0
      }
    },
    {
      "vertiport_id": "CDT",
      "city": "Chicago",
      "census_tract_id": "8419 (Cook, IL)",
      "type": "spoke",
      "fixed_driving_cost_USD": 20,
      "fato_capacity": 6,
      "coordinates": {
        "lat": 0,
        "lon": 0
      }
    },
    {
      "vertiport_id": "ORD",
      "city": "Chicago",
      "census_tract_id": "9800 (Cook, IL)",
      "type": "spoke",
      "fixed_driving_cost_USD": 20,
      "fato_capacity": 12,
      "coordinates": {
        "lat": 0,
        "lon": 0
      }
    },
    {
      "vertiport_id": "MDW",
      "city": "Chicago",
      "census_tract_id": "9801 (Cook, IL)",
      "type": "spoke",
      "fixed_driving_cost_USD": 20,
      "fato_capacity": 12,
      "coordinates": {
        "lat": 0,
        "lon": 0
      }
    }
  ],
  "links": {
    "nodes": ["UIU", "CDT", "ORD", "MDW"],
    "flight_time_matrix": [
      [  0, 55, 55, 50],
      [ 55,  0, 8, 8],
      [ 55, 8,  0, 8],
      [ 50, 8, 8,  0]
    ],
    "flight_distance_matrix": [
      [  0, 130, 130, 120],
      [130,   0,  15,  15],
      [130,  15,   0,  15],
      [120,  15,  15,   0]
    ]
  }
}
